# Copy to .env and adjust as needed. docker-compose reads this automatically.
# Every variable here has a safe default; override only what you need.

# --- Postgres credentials (local dev only — Railway generates these) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Qdrant ---
# Set a token to require authentication on Qdrant. Leave empty for local dev.
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# --- Embeddings ---
# fastembed (default) — runs locally, no API key needed.
EMBED_ENGINE=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Or OpenAI — uncomment and fill in to use OpenAI's embeddings API.
# EMBED_ENGINE=openai
# EMBED_ENGINE_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# --- App ---
SECRET_KEY=local-dev-secret-change-in-production
CORS_ORIGINS=http://localhost:3000
APP_ENV=development
APP_NAME=qdrant-starter-api
LOG_LEVEL=info
